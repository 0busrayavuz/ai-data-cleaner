# ─── Zorunlu ───────────────────────────────────────────────────────────────────
# PostgreSQL parolası. Güvenli rastgele bir değer seçin.
# Örnek: openssl rand -hex 32
POSTGRES_PASSWORD=change_me_use_a_strong_random_password

# JWT imzalama anahtarı. Güvenli rastgele bir değer seçin.
# Örnek: openssl rand -hex 32
SECRET_KEY=change_me_use_a_strong_random_secret

# ─── İsteğe bağlı — varsayılanlar aşağıda gösterilmiştir ─────────────────────
POSTGRES_USER=postgres
POSTGRES_DB=cleaner_db

# Kullanmak isteyenler için tam DATABASE_URL (yukarıdaki değişkenlerden otomatik oluşturulur)
# DATABASE_URL=postgresql://postgres:<POSTGRES_PASSWORD>@db:5432/cleaner_db

# ─── SMTP (parola sıfırlama e-postası) ────────────────────────────────────────
# Boş bırakılırsa token konsola yazdırılır (geliştirici modu).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─── Google Gemini AI yardımcı asistan ────────────────────────────────────────
# Boş bırakılırsa /assistant uç noktası 503 döner.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
